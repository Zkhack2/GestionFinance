# Variables d'environnement pour le backend Django
# Copie ce fichier en .env (gitignored) et adapte les valeurs.

# Clé secrète Django (ne jamais la partager)
DJANGO_SECRET_KEY=change-moi-super-securise

# Debug (True/False)
DJANGO_DEBUG=True

# Hôtes autorisés (séparés par des virgules)
# Ex: DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,mon-domaine.com
DJANGO_ALLOWED_HOSTS=*

# Base de données (PostgreSQL conseillé en prod)
# Ex: DATABASE_URL=postgres://user:password@host:port/dbname
# Laisser vide pour utiliser sqlite (dev)
DATABASE_URL=

# Origines CORS autorisées (séparées par des virgules)
# Ex: CORS_ALLOWED_ORIGINS=https://mon-frontend.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173
